{
  "name": "fieldglass",
  "displayName": "Fieldglass",
  "description": "VS Code extension for viewing meteorological data files (GRIB1, GRIB2, NetCDF)",
  "version": "0.1.3",
  "publisher": "fieldglass",
  "preview": true,
  "license": "MIT OR Apache-2.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#04274E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/D0ubleD0uble/fieldglass"
  },
  "bugs": {
    "url": "https://github.com/D0ubleD0uble/fieldglass/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "grib",
    "grib1",
    "grib2",
    "netcdf",
    "meteorology",
    "weather",
    "forecast"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fieldglass-grib1",
        "aliases": [
          "GRIB1",
          "grib1"
        ],
        "extensions": [
          ".grb",
          ".grib",
          ".grib1",
          ".grb1"
        ]
      },
      {
        "id": "fieldglass-grib2",
        "aliases": [
          "GRIB2",
          "grib2"
        ],
        "extensions": [
          ".grb2",
          ".grib2"
        ]
      },
      {
        "id": "fieldglass-netcdf",
        "aliases": [
          "NetCDF",
          "netcdf"
        ],
        "extensions": [
          ".nc",
          ".nc4",
          ".netcdf"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "fieldglass.viewer",
        "displayName": "Fieldglass Viewer",
        "selector": [
          {
            "filenamePattern": "*.grb"
          },
          {
            "filenamePattern": "*.grib"
          },
          {
            "filenamePattern": "*.grib1"
          },
          {
            "filenamePattern": "*.grb1"
          },
          {
            "filenamePattern": "*.grb2"
          },
          {
            "filenamePattern": "*.grib2"
          },
          {
            "filenamePattern": "*.nc"
          },
          {
            "filenamePattern": "*.nc4"
          },
          {
            "filenamePattern": "*.netcdf"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "fieldglass.viewer.any",
        "displayName": "Fieldglass Viewer",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile && node scripts/copy-package-files.cjs"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.9.2",
    "@types/vscode": "~1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.0",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.6",
    "typescript": "^6.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}

/target/
node_modules/
extension/out/
extension/.vscode-test/
extension/bin/*.node
extension/bin/*.js
extension/bin/*.d.ts
# napi-rs artifacts at crate root (generated during dev before bin/ was added)
*.node
index.d.ts
index.js

# Manual-testing sample files: real full operational files fetched by
# tools/fetch_samples.sh for eyeballing renders. Large and licence-varied, so
# the data stays local; only the checklist (samples/README.md) is tracked.
/samples/*
!/samples/README.md

# Local-only planning notes — kept on disk for the maintainer, not tracked.
PLAN.md

# LLM assistant files — kept locally as developer notes, never tracked,
# except .claude/rules/ which holds committed project conventions that must
# carry over to cloud / GitHub Action / routine sessions (user-scoped
# ~/.claude does not).
.claude/*
!.claude/rules/
CLAUDE.md
.cursor/
.cursorrules
.aider*
.continue/
.copilot-instructions.md
.github/copilot-instructions.md

# Coverage artifacts (generated by cargo llvm-cov in CI; never committed).
lcov.info
*.profraw
*.profdata

# Marketplace-display copies, populated by extension/scripts/copy-package-files.cjs
# at vsce package time. Source of truth is the repo root.
extension/README.md
extension/CHANGELOG.md
extension/*.vsix

# Python bytecode cache from tools/ scripts
__pycache__/
*.pyc
